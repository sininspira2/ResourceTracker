{
  "name": "resource-tracker",
  "version": "4.1.6",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate-hashes && next build",
    "release:migrate": "tsx scripts/db-migrate-if-configured.ts",
    "release:backfill": "tsx scripts/backfill-inventory-locations.ts",
    "start": "next start",
    "lint": "eslint .",
    "test": "cross-env NODE_OPTIONS=--no-warnings jest",
    "db:generate": "drizzle-kit generate && npm run db:generate-hashes",
    "db:generate-hashes": "tsx scripts/generate-migration-hashes.ts",
    "db:push": "drizzle-kit push",
    "db:log-init": "tsx --env-file .env.local scripts/log-initial-migration.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "tsx --env-file .env.local scripts/check-migrations.ts",
    "db:check:drop": "tsx --env-file .env.local scripts/check-migrations.ts --drop",
    "update-version": "node scripts/update-version.js",
    "populate-resources": "tsx --env-file .env.local scripts/populate-resources.ts",
    "populate-resources-dune": "tsx --env-file .env.local scripts/populate-resources-dune.ts",
    "populate-blueprints-dune": "tsx --env-file .env.local scripts/populate-blueprints-dune.ts",
    "add-resources-with-images": "tsx --env-file .env.local scripts/add-resources-with-images.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@headlessui/react": "^2.2.10",
    "@libsql/client": "^0.17.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.11.0",
    "nanoid": "^5.1.9",
    "next": "15.5.15",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.5.0"
  },
  "overrides": {
    "nodemailer": "^7.0.7",
    "esbuild": "^0.25.0",
    "picomatch": "2.3.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.59.1",
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.2.0",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1"
  }
}
